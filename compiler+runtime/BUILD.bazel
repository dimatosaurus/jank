package(default_visibility = ["//visibility:public"])

# ---------- Runtime resource directory ----------
# Assembled tree of files needed by jank at runtime (JIT headers, .jank
# sources, hermetic clang binary, clang resource dir).

filegroup(
    name = "jank_sources",
    srcs = glob(["src/jank/**/*.jank"]),
)

filegroup(
    name = "jank_runtime_headers",
    srcs = glob([
        "include/cpp/**/*.hpp",
        "include/cpp/**/*.h",
    ]),
)

LLVM_TOOLCHAIN = "@@llvm++http_archive+llvm-toolchain-minimal-22.1.0-darwin-arm64"

# ---------- Precompiled header (PCH) ----------
# The JIT loads this PCH on startup so it knows all jank runtime types.
# Building it as a Bazel action means Bazel tracks its deps and
# invalidates it when headers change — no more stale PCH issues.

genrule(
    name = "incremental_pch",
    srcs = [
        ":jank_runtime_headers",
        ":jank_resource",
    ],
    outs = ["incremental.pch"],
    cmd = """
        RESOURCE="$$(pwd)/$(location :jank_resource)"
        CLANG="$$RESOURCE/bin/clang++"
        SYSROOT=$$(/usr/bin/xcrun --show-sdk-path 2>/dev/null || true)
        SYSROOT_FLAG=""
        if [ -n "$$SYSROOT" ]; then
            SYSROOT_FLAG="-isysroot $$SYSROOT"
        fi
        "$$CLANG" \
            -std=gnu++20 -femulated-tls \
            -DGC_THREADS -DIMMER_HAS_LIBGC=1 -DIMMER_TAGGED_NODE=0 \
            -DHAVE_CXX14=1 -DCPPINTEROP_USE_REPL \
            -DFOLLY_HAVE_JEMALLOC=0 -DFOLLY_HAVE_TCMALLOC=0 \
            -DFOLLY_ASSUME_NO_JEMALLOC=1 -DFOLLY_ASSUME_NO_TCMALLOC=1 \
            -I "$$RESOURCE/include" \
            -I "$$RESOURCE/include/c++/v1" \
            -nostdinc++ \
            -resource-dir "$$("$$CLANG" -print-resource-dir)" \
            $$SYSROOT_FLAG \
            -Xclang -fincremental-extensions \
            -Xclang -emit-pch \
            -Xclang -fmodules-embed-all-files \
            -fno-modules-validate-system-headers \
            -fpch-instantiate-templates \
            -Xclang -fno-validate-pch \
            -Xclang -fno-pch-timestamp \
            -x c++-header \
            -w \
            -o $@ \
            -c "$$RESOURCE/include/jank/prelude.hpp"
    """,
    visibility = ["//visibility:public"],
)

jank_resource_dir(
    name = "jank_resource",
    jank_sources = [":jank_sources"],
    jank_headers = [":jank_runtime_headers"],
    third_party_headers = [
        "@bdwgc//:hdrs",
        "@nanobench//:hdrs",
        "@folly//:hdrs",
        "@immer//:hdrs",
        "@ftxui//:hdrs",
        "@cpptrace//:hdrs",
        "@cppinterop//:hdrs",
        "@cppinterop//:lib_hdrs",
        "@boost-preprocessor//:hdrs",
        "@boost-multiprecision//:hdrs",
    ],
    third_party_header_strips = [
        "",
        "",
        "",
        "",
        "",
        "",
        "",
        "lib/",
        "",
        "",
    ],
    third_party_header_prefixes = [
        "",        # bdwgc: include/gc.h → include/gc.h
        "",        # nanobench: include/nanobench.h → include/nanobench.h
        "include", # folly: folly/*.h → include/folly/*.h
        "include", # immer: immer/**/*.hpp → include/immer/**/*.hpp
        "",        # ftxui: include/ftxui → include/ftxui
        "",        # cpptrace: include/cpptrace → include/cpptrace
        "",        # cppinterop: include/CppInterOp → include/CppInterOp
        "include", # cppinterop/lib: CppInterOp/*.h → include/CppInterOp/*.h
        "",        # boost-preprocessor: include/boost → include/boost
        "",        # boost-multiprecision: include/boost → include/boost
    ],
    clang_binary = [LLVM_TOOLCHAIN + "//:clang++"],
    sysroot = ["@@llvm++osx+macos_sdk//sysroot:sysroot_source_directory"],
    clang_resource_dir = [LLVM_TOOLCHAIN + "//:builtin_resource_dir_files"],
)

# Full resource dir including static libraries for AOT compilation.
# Separate from jank_resource to avoid a cycle: the static libs depend
# on jank_library targets which themselves need the base jank_resource.
jank_resource_dir(
    name = "jank_aot_resource",
    jank_sources = [":jank_sources"],
    jank_headers = [":jank_runtime_headers"],
    third_party_headers = [
        "@bdwgc//:hdrs",
        "@nanobench//:hdrs",
        "@folly//:hdrs",
        "@immer//:hdrs",
        "@ftxui//:hdrs",
        "@cpptrace//:hdrs",
        "@cppinterop//:hdrs",
        "@cppinterop//:lib_hdrs",
        "@boost-preprocessor//:hdrs",
        "@boost-multiprecision//:hdrs",
    ],
    third_party_header_strips = [
        "",
        "",
        "",
        "",
        "",
        "",
        "",
        "lib/",
        "",
        "",
    ],
    third_party_header_prefixes = [
        "",
        "",
        "include",
        "include",
        "",
        "",
        "",
        "include",
        "",
        "",
    ],
    clang_binary = [LLVM_TOOLCHAIN + "//:clang++"],
    sysroot = ["@@llvm++osx+macos_sdk//sysroot:sysroot_source_directory"],
    clang_resource_dir = [LLVM_TOOLCHAIN + "//:builtin_resource_dir_files"],
    static_libs = [
        ":libjank-standalone",
        ":libLLVM",
        ":libclang-cpp",
        ":libcrypto",
        ":libz",
        ":libzstd",
    ],
)

# ---------- Merged static archives for AOT linking ----------
# The AOT linker (processor.cpp) links against these by name.

merge_archives(
    name = "libjank-standalone",
    output_name = "libjank-standalone.a",
    deps = [
        ":jank_lib",
        "@cppinterop",
        "@cpptrace",
        "@ftxui//:screen",
        "@ftxui//:dom",
        "@nanobench",
        "@bdwgc//:gc",
        "@bdwgc//:gctba",
        "@folly",
        "@zip",
        # compiler-rt builtins (provides __emutls_get_address for -femulated-tls)
        "@@llvm++llvm_source+compiler-rt//:builtins",
    ],
    # Compiled core modules — the AOT entrypoint calls jank_load_clojure_core() etc.
    extra_objects = [
        ":clojure_core",
        ":clojure_string",
        ":clojure_walk",
    ],
)

