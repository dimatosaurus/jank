    deps = [":clojure_core"],
)

jank_library(
    name = "clojure_walk",
    module = "clojure.walk",
    srcs = ["src/jank/clojure/walk.jank"],
    deps = [":clojure_core"],
)

# ---------- AOT compilation support ----------
# The jank binary resolves JANK_RESOURCE_DIR="jank_resource" relative to
# its own directory.  For AOT we need the resource dir to include static
# libraries.  This wrapper symlinks jank_aot_resource as jank_resource
# next to the real binary, then execs it.

genrule(
    name = "gen_jank_aot_script",
    outs = ["jank_aot.sh"],
    cmd = """cat > $@ << 'SCRIPT'
#!/bin/bash
set -euo pipefail
# Resolve runfiles.
if [[ -n "$${RUNFILES_DIR:-}" ]]; then
  R="$${RUNFILES_DIR}/_main"
elif [[ -d "$${BASH_SOURCE[0]}.runfiles" ]]; then
  R="$${BASH_SOURCE[0]}.runfiles/_main"
else
  echo "error: cannot find runfiles" >&2; exit 1
fi
# jank resolves JANK_RESOURCE_DIR="jank_resource" relative to its own
# canonical directory.  We need the AOT resource dir (which contains
# static libraries) to be at that path.  Create a staging directory
# with a copy of the binary and a symlink to the AOT resource dir.
REAL_JANK="$$(python3 -c "import os,sys;print(os.path.realpath(sys.argv[1]))" "$$R/jank")"
REAL_AOT="$$(python3 -c "import os,sys;print(os.path.realpath(sys.argv[1]))" "$$R/jank_aot_resource")"
STAGE="/tmp/jank-aot-stage"
mkdir -p "$$STAGE"
cp -f "$$REAL_JANK" "$$STAGE/jank" 2>/dev/null || true
chmod +x "$$STAGE/jank"
ln -sfn "$$REAL_AOT" "$$STAGE/jank_resource"
exec "$$STAGE/jank" "$$@"
SCRIPT
""",
)

sh_binary(
    name = "jank_aot",
    srcs = [":gen_jank_aot_script"],
    data = [
        ":jank",
        ":jank_aot_resource",
    ],
)
